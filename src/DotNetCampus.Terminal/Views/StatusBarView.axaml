<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DotNetCampus.Terminal.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="30"
             x:Class="DotNetCampus.Terminal.Views.StatusBarView"
             x:DataType="vm:StatusBarViewModel"
             Height="16">

    <Design.DataContext>
        <vm:StatusBarViewModel />
    </Design.DataContext>

    <!--
    全局功能键定义 (Global Function Keys):
    F1  - 帮助     显示帮助文档或操作指南 (已实现 - 跳转到GitHub仓库)
    F2  - 连接     测试设备连接状态，更新连接指示器 (待其他AI实现)
    F3  - 同步     启动文件同步操作 (待其他AI实现)
    F4  - 新建     创建新设备配置 (待其他AI实现)
    F5  - 刷新     刷新设备列表和连接状态 (已实现)
    F6  - 保存     保存当前设备的配置修改 (待其他AI实现)
    F7  - 终端     在新标签页中打开SSH命令行会话 (待其他AI实现)
    F8  - 搜索     切换搜索模式或焦点 (待实现)
    F9  - 设置     打开应用程序全局设置 (待实现)
    F10 - 退出     安全退出应用程序 (已实现)

    注意事项:
    - F2 和 F7 的区别：F2只测试连接状态，F7打开实际的终端交互
    - F6 只有在设备配置有未保存修改时才应该可用
    - 所有需要选中设备的功能键在未选中时应该禁用
    -->

    <UserControl.Styles>
        <Style Selector="TextBlock.Fn">
            <Setter Property="Background" Value="Black" />
            <Setter Property="Foreground" Value="DimGray" />
            <Setter Property="Padding" Value="1 0 0 0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Foreground" Value="DimGray" />
            <Setter Property="Background" Value="Transparent" />
            <Style Selector="^.Hidden">
                <Setter Property="Foreground" Value="Black" />
            </Style>
            <Style Selector="^.Hidden TextBlock.Fn">
                <Setter Property="Foreground" Value="Black" />
            </Style>
            <Style Selector="^ /template/ Border#InternalBorder">
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="^:clickdelayed /template/ Border#InternalBorder">
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="Green" />
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="^:pointerover TextBlock.Fn">
                <Setter Property="Background" Value="White" />
                <Setter Property="Foreground" Value="Black" />
            </Style>
        </Style>
        <Style Selector="#StatusBarPanel>Button">
            <Setter Property="Padding" Value="0 0 1 0" />
            <Setter Property="Margin" Value="0" />
            <Style Selector="^:clickdelayed">
                <Setter Property="Padding" Value="0 0 1 0" />
            </Style>
        </Style>
    </UserControl.Styles>

    <StackPanel x:Name="StatusBarPanel" Orientation="Horizontal">
        <!-- F1 - 帮助 (跳转到GitHub仓库) -->
        <Button Command="{Binding ShowHelpCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F1,显示帮助文档和操作指南,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F1" Classes="Fn" />
                <TextBlock Text="帮助" />
            </StackPanel>
        </Button>

        <!-- F2 - 连接 (待其他AI实现) -->
        <Button Classes="Hidden"
                Command="{Binding ConnectCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F2,测试当前选中设备的连接状态,False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F2" Classes="Fn" />
                <TextBlock Text="连接" />
            </StackPanel>
        </Button>

        <!-- F3 - 同步 (待其他AI实现) -->
        <Button Command="{Binding StartSyncCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F3,启动当前选中设备的文件同步,False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F3" Classes="Fn" />
                <TextBlock Text="同步" />
            </StackPanel>
        </Button>

        <!-- F4 - 新建 (待其他AI实现) -->
        <Button Classes="Hidden"
                Command="{Binding NewDeviceCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F4,创建新的远程设备配置,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F4" Classes="Fn" />
                <TextBlock Text="新建" />
            </StackPanel>
        </Button>

        <!-- F5 - 刷新 (已实现) -->
        <Button Command="{Binding RefreshCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F5,刷新设备列表和连接状态,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F5" Classes="Fn" />
                <TextBlock Text="刷新" />
            </StackPanel>
        </Button>

        <!-- F6 - 保存 (待其他AI实现) -->
        <Button Classes="Hidden"
                Command="{Binding SaveConfigCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F6,保存当前设备的配置修改,False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F6" Classes="Fn" />
                <TextBlock Text="保存" />
            </StackPanel>
        </Button>

        <!-- F7 - 终端 (待其他AI实现) -->
        <Button Classes="Hidden"
                Command="{Binding OpenShellCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F7,在新终端标签页中打开SSH会话,False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F7" Classes="Fn" />
                <TextBlock Text="终端" />
            </StackPanel>
        </Button>

        <!-- F8 - 搜索 (待实现) -->
        <Button Classes="Hidden"
                Command="{Binding ToggleSearchCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F8,切换搜索模式或搜索框焦点,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F8" Classes="Fn" />
                <TextBlock Text="搜索" />
            </StackPanel>
        </Button>

        <!-- F9 - 设置 (待实现) -->
        <Button Classes="Hidden"
                Command="{Binding SettingsCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F9,打开应用程序全局设置,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F9" Classes="Fn" />
                <TextBlock Text="设置" />
            </StackPanel>
        </Button>

        <!-- F10 - 退出 (已实现) -->
        <Button Command="{Binding ExitCommand}"
                PointerEntered="OnFunctionKeyHover"
                PointerExited="OnFunctionKeyLeave"
                Tag="F10,安全退出应用程序,True">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="F10" Classes="Fn" />
                <TextBlock Text="退出" />
            </StackPanel>
        </Button>
    </StackPanel>

</UserControl>
