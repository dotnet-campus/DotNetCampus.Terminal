<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Walterlv.Terminal.Views.MainView">

    <Grid RowDefinitions="40,*,Auto" ColumnDefinitions="Auto,*">
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Width="240">

        </Grid>
        <Grid Grid.Row="1" Grid.Column="1" Background="Black">

        </Grid>
        <Grid Grid.Row="2" Grid.Column="1" Height="240" Background="#111111">

        </Grid>
    </Grid>

</UserControl>
