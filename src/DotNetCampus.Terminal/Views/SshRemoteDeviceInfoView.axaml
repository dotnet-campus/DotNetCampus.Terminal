<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:console="https://github.com/jinek/consolonia"
             xmlns:models="clr-namespace:DotNetCampus.Terminal.Modules.Configurations.Models"
             xmlns:vm="clr-namespace:DotNetCampus.Terminal.ViewModels"
             xmlns:converters="clr-namespace:DotNetCampus.Terminal.Views.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DotNetCampus.Terminal.Views.SshRemoteDeviceInfoView"
             x:DataType="vm:SshRemoteDeviceInfoViewModel">

    <Design.DataContext>
        <vm:SshRemoteDeviceInfoViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToBackgroundConverter"
                                                    Default="DimGray"
                                                    Online="Green"
                                                    Offline="DarkRed" />
        <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToForegroundConverter"
                                                    Default="Green"
                                                    Testing="Yellow"
                                                    Offline="Red" />
        <converters:ConnectionStateToStringConverter x:Key="ConnectionStateToSymbolConverter"
                                                     Default="○"
                                                     Testing="?"
                                                     Online="●"
                                                     Offline="✗" />
        <converters:ConnectionStateToStringConverter x:Key="ConnectionStateToStringConverter"
                                                     Default="未知"
                                                     Online="在线"
                                                     Offline="离线" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="Green" />
            <Setter Property="Padding" Value="1 0" />
            <Setter Property="console:ButtonExtensions.Shadow" Value="False" />
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="LightGreen" />
            </Style>
            <Style Selector="^:clickdelayed">
                <Setter Property="Padding" Value="1 0" />
                <Setter Property="Background" Value="DarkGreen" />
            </Style>
            <Style Selector="^ /template/ Border#InternalBorder">
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="^:clickdelayed /template/ Border#InternalBorder">
                <Setter Property="Margin" Value="0" />
            </Style>
        </Style>
        <Style Selector="UniformGrid TextBox">
            <Setter Property="Margin" Value="0 0 0 1" />
            <Style Selector="^:nth-last-child(1)">
                <Setter Property="Margin" Value="0" />
            </Style>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
        <Grid Margin="1" RowDefinitions="Auto,*" ColumnDefinitions="*">

            <StackPanel Grid.Row="0">

                <!-- 连接名称标题 -->
                <TextBox FontWeight="Bold"
                         TextAlignment="Center" Background="White"
                         Text="{Binding ConnectionName, Mode=TwoWay}" />

                <!-- 连接状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <TextBlock Width="2"
                               Text="{Binding ConnectionState, Converter={StaticResource ConnectionStateToSymbolConverter}, Mode=OneWay}"
                               Foreground="{Binding ConnectionState, Converter={StaticResource ConnectionStateToForegroundConverter}, Mode=OneWay}" />
                    <TextBlock Width="8"
                               Text="{Binding ConnectionState, Converter={StaticResource ConnectionStateToStringConverter}, Mode=OneWay}" />
                    <Button Content="连接" Margin="1,0" />
                </StackPanel>

                <!-- 主机地址/端口、用户名/密码分组 -->
                <UniformGrid Columns="2">
                    <!-- 主机地址+端口分组 -->
                    <Border BorderThickness="1" BorderBrush="DimGray">
                        <StackPanel Margin="1">
                            <TextBlock Text="主机地址" />
                            <TextBox Text="{Binding Host, Mode=TwoWay}" />
                            <TextBlock Text="端口" />
                            <TextBox Text="{Binding Port, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                    <!-- 用户名+密码分组 -->
                    <Border BorderThickness="1" BorderBrush="DimGray">
                        <StackPanel Margin="1">
                            <TextBlock Text="用户名" />
                            <TextBox Text="{Binding UserName, Mode=TwoWay}" />
                            <TextBlock Text="密码" />
                            <TextBox Text="{Binding Password, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- 保存与重置 -->
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,1">
                    <Button Content="保存" Margin="1,0" />
                    <Button Content="重置" Margin="1,0" />
                </StackPanel>
            </StackPanel>

            <!-- 目录同步配置区 -->
            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Margin="0,1">

                <!-- 同步组列表标题 -->
                <TextBlock Grid.Row="0" Text="目录同步配置"
                           FontWeight="Bold" TextAlignment="Center"
                           Background="White" Foreground="Black"
                           Margin="0,0,0,1" />

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="2" Margin="0,1">
                    <Button Content="新增同步目录" />
                    <Button Content="立即同步" />
                    <Button Content="全部启用" />
                    <Button Content="全部禁用" />
                </StackPanel>

                <!-- 同步组列表 -->
                <ListBox Grid.Row="2" BorderThickness="0"
                         ItemsSource="{Binding SyncGroups}"
                         SelectedItem="{Binding SelectedSyncGroup}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SyncGroupViewModel">
                            <Border BorderThickness="1" BorderBrush="DimGray">
                                <StackPanel Margin="1">
                                    <!-- 同步组名称和状态 -->
                                    <Grid ColumnDefinitions="3,Auto,*,Auto,Auto,Auto">
                                        <TextBlock Grid.Column="0" Width="3"
                                                   TextAlignment="Center"
                                                   Text="{Binding StatusSymbol}"
                                                   Foreground="{Binding StatusColor}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Margin="1,0,0,0" />
                                        <ToggleSwitch Grid.Column="3" Margin="1,0" OnContent="已启用" OffContent="已禁用" />
                                        <Button Grid.Column="4" Content="编辑" Margin="1,0" />
                                        <Button Grid.Column="5" Content="✗" Margin="1,0" />
                                    </Grid>
                                    <!-- 远程路径 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                        <TextBlock Width="3" Text="📁" />
                                        <TextBlock Text="{Binding RemotePath}" />
                                    </StackPanel>
                                    <!-- 同步方向 -->
                                    <TextBlock Width="3" Text=" ↑" HorizontalAlignment="Left" />
                                    <!-- 本地路径 -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Width="3" Text="📁" />
                                        <TextBlock Text="{Binding LocalPath}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Grid>
    </ScrollViewer>

</UserControl>
