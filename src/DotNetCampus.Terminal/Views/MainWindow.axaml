<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:DotNetCampus.Terminal.Views"
        xmlns:l="using:DotNetCampus.Terminal.Localizations"
        x:Class="DotNetCampus.Terminal.Views.MainWindow"
        Width="1280" Height="960" WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica,AcrylicBlur,Blur"
        ExtendClientAreaToDecorationsHint="True" ExtendClientAreaTitleBarHeightHint="40" Background="Transparent"
        Title="{Binding Product.LocalizedName, Source={x:Static l:Lang.Current}}">

    <views:MainView />

</Window>
