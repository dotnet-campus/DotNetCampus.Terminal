<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DotNetCampus.Terminal.ViewModels"
             xmlns:m="using:DotNetCampus.Terminal.Modules.Configurations.Models"
             xmlns:configurations="using:DotNetCampus.Terminal.Modules.Configurations"
             xmlns:views="using:DotNetCampus.Terminal.Views"
             xmlns:converters="using:DotNetCampus.Terminal.Views.Converters"
             xmlns:l="using:DotNetCampus.Terminal.Localizations"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DotNetCampus.Terminal.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToBackgroundConverter"
                                                    Default="DimGray"
                                                    Online="Green"
                                                    Offline="DarkRed" />
        <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToForegroundConverter"
                                                    Default="White"
                                                    Testing="DarkGray"
                                                    Offline="Red" />
        <converters:ConnectionStateToStringConverter x:Key="ConnectionStateToStringConverter"
                                                     Default=" "
                                                     Testing="o"
                                                     Offline="x" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.TitleBar">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="12 0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="32,*,Auto" ColumnDefinitions="*,2*">

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Grid.Column="0" x:Name="TitleBarBorder"
                IsHitTestVisible="False" Margin="0 0 0 -4">
            <TextBlock Classes="TitleBar" Foreground="#CCCCCC" VerticalAlignment="Center"
                       Text="{Binding Product.LocalizedName, Source={x:Static l:Lang.Current}}" />
        </Border>

        <!-- 左侧设备列表 -->
        <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*">

            <TextBox Grid.Row="0" Margin="12 4" Watermark="搜索设备…" />

            <TreeView x:Name="DeviceTreeView" Grid.Row="1" BorderThickness="0"
                      ItemsSource="{Binding RemoteDevices}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="Foreground" Value="#CCCCCC" />
                        <Setter Property="Margin" Value="6 0" />
                        <Setter Property="Padding" Value="0 0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="IsExpanded" Value="True" />
                        <Style Selector="^ /template/ Border#PART_LayoutRoot">
                            <Setter Property="Height" Value="40" />
                            <Setter Property="Margin" Value="8 4" />
                        </Style>
                        <Style Selector="^ /template/ Panel#PART_ExpandCollapseChevronContainer">
                            <Setter Property="Grid.Column" Value="1" />
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                        <Style Selector="^[Level=0]">
                            <Setter Property="Foreground" Value="#EEEEEE" />
                            <Setter Property="Padding" Value="12 0" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="Margin" Value="-4 0" />
                            <Setter Property="BorderThickness" Value="0 0.6 0 0" />
                            <Setter Property="BorderBrush" Value="#80000000" />
                            <Style Selector="^ /template/ Border#PART_LayoutRoot">
                                <Setter Property="Height" Value="48" />
                                <Setter Property="Margin" Value="4 0" />
                            </Style>
                            <Style Selector="^:nth-child(1)">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </Style>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <ContentControl Content="{Binding}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.DataTemplates>
                    <DataTemplate x:DataType="vm:CreateNewRemoteDeviceNode">
                        <Border Background="Transparent">
                            <TextBlock>
                                <Run Text="🔗" />
                                <Run Text="连接到新设备" FontWeight="Bold" />
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                    <DataTemplate x:DataType="vm:FavoriteDeviceGroupNode">
                        <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent">
                            <TextBlock Grid.Column="0">
                                <Run Text="⭐" />
                                <Run Text="收藏" FontWeight="Bold" />
                            </TextBlock>
                            <Border Grid.Column="1" BorderThickness="0 0 0 1" BorderBrush="DimGray">
                            </Border>
                            <TextBlock Grid.Column="2" Padding="1 0" Classes="TreeViewExpander"
                                       Foreground="DarkGray" />
                        </Grid>
                    </DataTemplate>
                    <DataTemplate x:DataType="vm:RemoteDeviceGroupNode">
                        <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent">
                            <TextBlock Grid.Column="0">
                                <Run Text="📁" />
                                <Run FontWeight="Bold"
                                     Text="{Binding Info.Name, Mode=OneWay}" />
                                <Run Text="(" /><Run Text="{Binding OnlineCount, Mode=OneWay}" />
                                <Run Text="/" />
                                <Run Text="{Binding Children.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                            <TextBlock Grid.Column="2" Padding="1 0" Classes="TreeViewExpander"
                                       Foreground="DarkGray" />
                        </Grid>
                    </DataTemplate>
                    <DataTemplate x:DataType="vm:SshRemoteDeviceInfoViewModel">
                        <Grid RowDefinitions="*,*" ColumnDefinitions="Auto,*,Auto" Background="Transparent">
                            <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                       Width="8" Margin="-4 0 12 0"
                                       Background="{Binding ConnectionState, Mode=OneWay, Converter={StaticResource ConnectionStateToBackgroundConverter}}"
                                       Foreground="{Binding ConnectionState, Mode=OneWay, Converter={StaticResource ConnectionStateToForegroundConverter}}"
                                       Text="{Binding ConnectionState, Mode=OneWay, Converter={StaticResource ConnectionStateToStringConverter}}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Info.ConnectionName, Mode=OneWay}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="SecondaryDescription"
                                       Text="{Binding Info.Address, Mode=OneWay}" />
                            <ToggleButton Grid.Row="0" Grid.Column="2" Classes="FavoriteIcon"
                                          IsCheckedChanged="FavoriteButton_IsCheckedChanged" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                       Margin="0 0 1 0" HorizontalAlignment="Right"
                                       IsVisible="{Binding HasUnsavedChanges, Mode=OneWay}">
                                <Run Text="💾" />
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>
        </Grid>

        <!-- 右侧设备详情 -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
              DataContext="{Binding #DeviceTreeView.SelectedItem}">
            <!-- 背景区域 -->
            <Border Background="#181818" 
                    BorderBrush="#2A2A2A" 
                    BorderThickness="1,0,0,0" 
                    IsHitTestVisible="False" />
            
            <!-- 内容区域 - 优化边距和布局 -->
            <Border Margin="16,32,16,16" 
                    Background="#202020" 
                    BorderBrush="#333333" 
                    BorderThickness="1" 
                    CornerRadius="8">
                <ContentControl Content="{Binding Mode=OneWay}" 
                                Margin="16">
                    <ContentControl.DataTemplates>
                        <DataTemplate x:DataType="vm:CreateNewRemoteDeviceNode">
                            <views:CreateNewRemoteDeviceView DataContext="{Binding ViewModel, Mode=OneWay}" />
                        </DataTemplate>
                        <DataTemplate x:DataType="vm:RemoteDeviceGroupNode">
                            <views:RemoteDeviceGroupView DataContext="{Binding Info, Mode=OneWay}" />
                        </DataTemplate>
                        <DataTemplate x:DataType="vm:SshRemoteDeviceInfoViewModel">
                            <views:SshRemoteDeviceInfoView DataContext="{Binding Mode=OneWay}" />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>

        <!-- 底部状态栏区域 -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" RowDefinitions="Auto,Auto">
            <!-- 状态提示栏 -->
            <views:StatusTipView Grid.Row="0" DataContext="{Binding StatusTip}" />

            <!-- 现代化状态栏 -->
            <views:StatusBarView Grid.Row="1" DataContext="{Binding StatusBar}" />
        </Grid>

    </Grid>
</UserControl>
