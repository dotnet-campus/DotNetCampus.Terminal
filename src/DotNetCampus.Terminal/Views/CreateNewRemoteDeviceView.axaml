<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DotNetCampus.Terminal.Views.CreateNewRemoteDeviceView">

    <Grid RowDefinitions="Auto,*"
          Margin="0">
        <!-- 标题区域 -->
        <Border Grid.Row="0"
                Background="#2A2A2A"
                BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                CornerRadius="4,4,0,0">
            <TextBlock Text="连接到新设备"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#EEEEEE" />
        </Border>

        <!-- 内容区域 -->
        <Border Grid.Row="1"
                Background="#1E1E1E"
                Padding="16">
            <Grid RowDefinitions="Auto,*" RowSpacing="16">
                <!-- 说明文字 -->
                <TextBlock Grid.Row="0"
                           Text="选择连接类型以添加新的远程设备"
                           FontSize="14"
                           Foreground="#CCCCCC"
                           TextAlignment="Center" />

                <!-- 展示图片 -->
                <Border Grid.Row="1"
                        Background="#252525"
                        BorderBrush="#404040"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Image Stretch="Uniform"
                           Source="avares://DotNetCampus.Terminal/Assets/Resources/happy.jpg"
                           MaxHeight="300" />
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
